<tbody>
<tr><td>第一层</td><td>静态信息（名称/地址/设施）</td><td>人工录入</td><td>95%+</td><td>Phase 1</td></tr>
<tr><td>第二层</td><td>准实时空档</td><td><b>场馆主主动填报</b></td><td>90%+</td><td>Phase 1</td></tr>
<tr><td>第三层</td><td>实时库存</td><td>新兴场馆 API 直连</td><td>95%+</td><td>Phase 3</td></tr>
</tbody>
